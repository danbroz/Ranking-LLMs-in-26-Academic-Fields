\hypertarget{rq1-do-any-current-large-language-models-llms-exhibit-statistically-uniform-performance-across-the-26-academic-fields-under-study}{%
\section*{RQ1: Do any current large-language models (LLMs) exhibit
statistically uniform performance across the 26 academic fields under
study?}\label{rq1-do-any-current-large-language-models-llms-exhibit-statistically-uniform-performance-across-the-26-academic-fields-under-study}}
\addcontentsline{toc}{section}{RQ1: Do any current large-language models
(LLMs) exhibit statistically uniform performance across the 26 academic
fields under study?}

\hypertarget{in-the-primary-evaluation-results-no-model-demonstrates-uniform-performance-across-all-26-academic-fields.-all-models-exhibit-observable-variability-in-field-level-scores-indicating-that-performance-varies-across-domains-even-when-evaluation-conditions-are-standardized.-for-example-openais-model-exhibits-field-level-results-ranging-from-the-low-60s-to-the-mid-to-upper-70s-depending-on-the-field-e.g.-economics-econometrics-and-finance-61.3-materials-science-76.5-and-chemical-engineering-76.5.-similarly-other-models-show-pronounced-drops-in-specific-domains-e.g.-groks-results-include-comparatively-low-outcomes-such-as-economics-econometrics-and-finance-26.8.-these-patterns-support-the-need-for-field-level-reporting-rather-than-reliance-on-a-single-overall-score.}{%
\section*{In the primary evaluation results, no model demonstrates
uniform performance across all 26 academic fields. All models exhibit
observable variability in field-level scores, indicating that
performance varies across domains even when evaluation conditions are
standardized. For example, OpenAI's model exhibits field-level results
ranging from the low 60s to the mid to upper 70s, depending on the field
(e.g., economics-econometrics-and-finance = 61.3, materials-science =
76.5, and chemical-engineering = 76.5). Similarly, other models show
pronounced drops in specific domains (e.g., Grok's results include
comparatively low outcomes such as economics-econometrics-and-finance =
26.8). These patterns support the need for field-level reporting rather
than reliance on a single overall
score.}\label{in-the-primary-evaluation-results-no-model-demonstrates-uniform-performance-across-all-26-academic-fields.-all-models-exhibit-observable-variability-in-field-level-scores-indicating-that-performance-varies-across-domains-even-when-evaluation-conditions-are-standardized.-for-example-openais-model-exhibits-field-level-results-ranging-from-the-low-60s-to-the-mid-to-upper-70s-depending-on-the-field-e.g.-economics-econometrics-and-finance-61.3-materials-science-76.5-and-chemical-engineering-76.5.-similarly-other-models-show-pronounced-drops-in-specific-domains-e.g.-groks-results-include-comparatively-low-outcomes-such-as-economics-econometrics-and-finance-26.8.-these-patterns-support-the-need-for-field-level-reporting-rather-than-reliance-on-a-single-overall-score.}}
\addcontentsline{toc}{section}{In the primary evaluation results, no
model demonstrates uniform performance across all 26 academic fields.
All models exhibit observable variability in field-level scores,
indicating that performance varies across domains even when evaluation
conditions are standardized. For example, OpenAI's model exhibits
field-level results ranging from the low 60s to the mid to upper 70s,
depending on the field (e.g., economics-econometrics-and-finance = 61.3,
materials-science = 76.5, and chemical-engineering = 76.5). Similarly,
other models show pronounced drops in specific domains (e.g., Grok's
results include comparatively low outcomes such as
economics-econometrics-and-finance = 26.8). These patterns support the
need for field-level reporting rather than reliance on a single overall
score.}

 The complete model-by-field score matrix is shown as a heatmap
in Figure~\ref{fig:heatmap}, and the within-model dispersion across the
26 fields is summarized in Figure~\ref{fig:variability-box}; together,
these figures provide the visual evidence underlying the conclusion
that no model exhibits statistically uniform performance across the
disciplinary taxonomy.

\begin{figure}[htbp]
\centering
\includegraphics[width=\linewidth]{figures/fig4_2_heatmap.png}
\caption{Field-level calibrated accuracy heatmap for the five evaluated
LLMs across all 26 academic fields. Greener cells indicate stronger
performance and redder cells indicate weaker performance; cell labels
report the underlying calibrated accuracy values.}
\label{fig:heatmap}
\end{figure}

\begin{figure}[htbp]
\centering
\includegraphics[width=0.9\linewidth]{figures/fig4_4_variability_box.png}
\caption{Distribution of field-level calibrated accuracy for each model
across the 26 academic fields. Box plots show the median, interquartile
range, and full range of field scores per model, with individual fields
overlaid as points to illustrate within-model variability (RQ1).}
\label{fig:variability-box}
\end{figure}


