"field\_35": "dentistry",

"field\_36": "health-professions",

\}

DATABASES = list(FIELD\_MAP.keys())

MONGO\_URI = "mongodb://localhost:27017/"

LOG\_PATH = Path("quiz\_apis.log")

CSV\_PATH = Path("results-apis.csv")

\emph{\# ────────── scoring constants ──────────}

CORRECT\_SCORE = 0.1 \emph{\# 1000 correct answers → 100 points}

INCORRECT\_SCORE = -0.1

\emph{\# Global tracking}

GLOBAL\_SALVAGE\_TOTAL: int = 0

GLOBAL\_SALVAGE\_BY\_MODEL: Dict{[}str, int{]} = \{\}

GLOBAL\_SALVAGE\_BY\_FIELD: Dict{[}str, int{]} = defaultdict(int)

\emph{\# ────────── logging ──────────}

logging.basicConfig(

\emph{level}=logging.INFO,

\emph{format}="\%(asctime)s --- \%(levelname)s --- \%(message)s",

\emph{handlers}={[}logging.StreamHandler(sys.stdout),
logging.FileHandler(LOG\_PATH, \emph{encoding}="utf-8"){]}

)

logging.getLogger("httpx").setLevel(logging.WARNING)

logging.getLogger("openai").setLevel(logging.WARNING)

logging.getLogger("anthropic").setLevel(logging.WARNING)

logger = logging.getLogger(\_\_name\_\_)

log, log\_warn, log\_err = logger.info, logger.warning, logger.error

\emph{\# ────────── API Client Initialization ──────────}

OPENAI\_CLIENT = None

GEMINI\_CLIENT = None

ANTHROPIC\_CLIENT = None

XAI\_API\_KEY = None

TOGETHER\_API\_KEY = None

TOGETHER\_API\_URL = "https://api.together.xyz/v1/chat/completions"

def \textbf{initialize\_api\_clients}():

"""Initialize API clients with keys from environment."""

global OPENAI\_CLIENT, GEMINI\_CLIENT, ANTHROPIC\_CLIENT, XAI\_API\_KEY,
TOGETHER\_API\_KEY

\emph{\# OpenAI}

openai\_key = os.getenv("OPENAI\_API\_KEY")

\emph{if} openai and openai\_key:

\emph{try}:

OPENAI\_CLIENT = openai.OpenAI(\emph{api\_key}=openai\_key,
\emph{timeout}=TIMEOUT\_SEC)

log("✅ OpenAI client initialized")

\emph{except} Exception \emph{as} e:

log\_err(f"Failed to initialize OpenAI client: \{e\}")

\emph{else}:

log\_warn("OpenAI API key not found or openai not installed")

\emph{\# Google Gemini}

google\_key = os.getenv("GOOGLE\_API\_KEY")

\emph{if} genai and google\_key:

\emph{try}:

genai.configure(\emph{api\_key}=google\_key)

GEMINI\_CLIENT = genai

log("✅ Google Gemini client initialized")

\emph{except} Exception \emph{as} e:

log\_err(f"Failed to initialize Gemini client: \{e\}")

\emph{else}:

log\_warn("Google API key not found or google-generativeai not
installed")

\emph{\# Anthropic Claude}

anthropic\_key = os.getenv("ANTHROPIC\_API\_KEY")

\emph{if} anthropic and anthropic\_key:

\emph{try}:

ANTHROPIC\_CLIENT = anthropic.Anthropic(\emph{api\_key}=anthropic\_key,
\emph{timeout}=TIMEOUT\_SEC * 1000) \emph{\# milliseconds}

log("✅ Anthropic Claude client initialized")

\emph{except} Exception \emph{as} e:

log\_err(f"Failed to initialize Anthropic client: \{e\}")

\emph{else}:

log\_warn("Anthropic API key not found or anthropic not installed")

\emph{\# x.ai Grok}

XAI\_API\_KEY = os.getenv("XAI\_API\_KEY")

\emph{if} XAI\_API\_KEY:

log("✅ x.ai API key loaded")

\emph{else}:

log\_warn("x.ai API key not found")

\emph{\# Together AI (for Llama 4 Maverick)}

together\_key = os.getenv("TOGETHER\_API\_KEY")

\emph{if} together\_key:

TOGETHER\_API\_KEY = together\_key

log("✅ Together AI API key loaded")

\emph{else}:

log\_warn("Together AI API key not found. Get one at:
https://www.together.ai/models/llama-4-maverick")

\emph{\# ────────── Model Discovery ──────────}

def \textbf{discover\_openai\_models}() -\textgreater{} List{[}str{]}:

"""Return GPT-5.1 with reasoning\_effort=none for non-reasoning
tasks."""

\emph{\# GPT-5.1 with reasoning\_effort=none - most powerful
non-reasoning model}

\emph{\# Order of preference: GPT-5.1, then fallbacks}

preferred\_models = {[}

"gpt-5.1", \emph{\# GPT-5.1 with reasoning\_effort=none (most powerful)}

"gpt-5.1-2025-04-14", \emph{\# Specific GPT-5.1 version}

"gpt-4.1", \emph{\# Fallback to GPT-4.1}

"gpt-4.1-2025-04-14", \emph{\# Specific GPT-4.1 version}

"gpt-4o", \emph{\# Fallback to GPT-4o}

"gpt-4-turbo", \emph{\# Fallback to GPT-4-turbo}

{]}

\emph{\# Exclude reasoning models and other unwanted models}

reasoning\_indicators = {[}"o1", "o3", "o4", "reasoning", "think"{]}

exclude\_indicators = {[}"embed", "code", "audio", "realtime", "search",
"transcribe"{]} + reasoning\_indicators

\emph{if} not OPENAI\_CLIENT:

\emph{\# Return GPT-5.1 as fallback}

model = preferred\_models{[}0{]} \emph{\# GPT-5.1}

log(f"OpenAI client not initialized, using GPT-5.1 with
reasoning\_effort=none: \{model\}")

\emph{return} {[}model{]}

\emph{\# Try to verify which models are available}

available\_models = {[}{]}

\emph{try}:

model\_list = OPENAI\_CLIENT.models.list()

available\_model\_ids = \{model.id \emph{for} model \emph{in}
model\_list.data\}

\emph{\# Return the first preferred model that\textquotesingle s
available}

\emph{for} model \emph{in} preferred\_models:

\emph{if} model in available\_model\_ids:

available\_models = {[}model{]}

log(f"Using GPT-5.1 with reasoning\_effort=none: \{model\}")

\emph{break}

\emph{\# If none of the preferred models are available, search for
GPT-5.1, GPT-4.1, GPT-4o, or GPT-4}

\emph{if} not available\_models:

\emph{for} model \emph{in} model\_list.data:

model\_id = model.id.lower()

\emph{\# Exclude reasoning models and other unwanted types}

\emph{if} any(exclude \emph{in} model\_id \emph{for} exclude \emph{in}
exclude\_indicators):

\emph{continue}

\emph{\# Prioritize GPT-5.1, then GPT-4.1, GPT-4o, GPT-4-turbo, GPT-4
(but NOT o1, o3, o4)}

\emph{if} ("gpt-5.1" in model\_id or "gpt-4.1" in model\_id or "gpt-4o"
in model\_id or "gpt-4-turbo" in model\_id or

(model\_id.startswith("gpt-") and not any(r \emph{in} model\_id
\emph{for} r \emph{in} reasoning\_indicators))):

available\_models = {[}model.id{]}

log(f"Using available OpenAI model with reasoning\_effort=none:
\{model.id\}")

\emph{break}

\emph{except} Exception \emph{as} e:

log\_warn(f"Error checking OpenAI models, using fallback: \{e\}")

\emph{\# Fallback to most likely available non-reasoning model}

available\_models = {[}preferred\_models{[}0{]}{]}

\emph{if} not available\_models:

available\_models = {[}preferred\_models{[}0{]}{]} \emph{\# Final
fallback to GPT-5.1}

log(f"Using fallback GPT-5.1 with reasoning\_effort=none:
\{available\_models{[}0{]}\}")

\emph{return} available\_models

def \textbf{discover\_gemini\_models}() -\textgreater{} List{[}str{]}:

"""Return Gemini 3 Pro for non-reasoning tasks."""

\emph{\# Use Gemini 3 Pro - most powerful non-reasoning Gemini model}

preferred\_models = {[}

"gemini-3-pro", \emph{\# Gemini 3 Pro (primary, non-flash)}

"gemini-3-pro-preview", \emph{\# Fallback to Gemini 3 Pro preview}

"gemini-2.5-pro", \emph{\# Fallback to Gemini 2.5 Pro}

"gemini-2.0-flash", \emph{\# Fallback to Gemini 2.0 Flash}

{]}

\emph{\# Exclude reasoning models, embeddings, and specialized models}

reasoning\_indicators = {[}"reasoning", "think", "cot"{]}

exclude\_indicators = {[}"embed", "image-generation", "vision", "audio",
"code", "live", "native-audio", "tts", "computer-use"{]} +
reasoning\_indicators

\emph{if} not GEMINI\_CLIENT:

\emph{\# Return Gemini 3 Pro as fallback}

model = "gemini-3-pro"

log(f"Gemini client not initialized, using gemini-3-pro: \{model\}")

\emph{return} {[}model{]}

available\_models = {[}{]}

\emph{try}:

\emph{\# Try to list available models}

model\_list = GEMINI\_CLIENT.list\_models()

available\_model\_names = \{model.name.lower() \emph{for} model
\emph{in} model\_list\}

\emph{\# Return the first preferred model that\textquotesingle s
available}

\emph{for} model \emph{in} preferred\_models:

\emph{\# Check if model is available}

\emph{for} available\_name \emph{in} available\_model\_names:

\emph{\# Use strict matching to avoid substring issues}

\emph{\# Match exact model name or models/\{model\} format}

model\_matches = (

available\_name == model.lower() or

available\_name.endswith(f"/\{model\}") or

available\_name == f"models/\{model\}"

)

\emph{\# Only proceed if we have an exact match}

\emph{if} not model\_matches:

\emph{continue}

\emph{\# Check it\textquotesingle s not a specialized model}

\emph{if} any(exclude \emph{in} available\_name \emph{for} exclude
\emph{in} exclude\_indicators):

\emph{continue}

\emph{\# Extract clean model ID}

model\_id = available\_name.split("/"){[}-1{]} \emph{if} "/" in
available\_name \emph{else} available\_name

available\_models = {[}model\_id{]}

log(f"Using gemini-3-pro: \{model\_id\}")

\emph{break}

\emph{if} available\_models:

\emph{break}

\emph{\# If none of preferred found, look for any gemini-3-pro variant}

\emph{if} not available\_models:

\emph{for} model \emph{in} model\_list:

model\_name = model.name.lower()

\emph{\# Skip embeddings and specialized models}

\emph{if} any(exclude \emph{in} model\_name \emph{for} exclude \emph{in}
exclude\_indicators):

\emph{continue}

\emph{\# Look for gemini-3-pro (non-flash, non-image)}

\emph{if} "gemini-3-pro" in model\_name and "flash" not in model\_name
and "image" not in model\_name:

model\_id = model\_name.split("/"){[}-1{]} \emph{if} "/" in model\_name
\emph{else} model\_name

available\_models = {[}model\_id{]}

log(f"Using available gemini-3-pro: \{model\_id\}")

\emph{break}

\emph{except} Exception \emph{as} e:

log\_warn(f"Error checking Gemini models, using fallback: \{e\}")

available\_models = {[}"gemini-3-pro"{]}

\emph{if} not available\_models:

available\_models = {[}"gemini-3-pro"{]} \emph{\# Final fallback to
gemini-3-pro}

log(f"Using fallback gemini-3-pro: \{available\_models{[}0{]}\}")

\emph{return} available\_models

def \textbf{discover\_claude\_models}() -\textgreater{} List{[}str{]}:

"""Return Claude Opus 4.1 non-reasoning model."""

\emph{\# Claude Opus 4.1 - most powerful non-reasoning Claude model}

\emph{\# Order of preference: Claude Opus 4.1, then fallbacks}

preferred\_models = {[}

"claude-opus-4-1", \emph{\# Claude Opus 4.1 alias (primary)}

"claude-opus-4-1-20250805", \emph{\# Claude Opus 4.1 specific version}

"claude-3-opus-20240229", \emph{\# Fallback to Claude 3 Opus}

"claude-3-5-sonnet-20241022", \emph{\# Fallback to Claude 3.5 Sonnet}

{]}

\emph{\# Exclude reasoning models (o1, o3, o4)}

reasoning\_indicators = {[}"o1", "o3", "o4", "reasoning"{]}

\emph{\# Use Claude Opus 4.1 - most powerful non-reasoning model}

\emph{\# Anthropic doesn\textquotesingle t have a public model listing
API, so we\textquotesingle ll use the most likely available}

model = preferred\_models{[}0{]} \emph{\# Start with Claude Opus 4.1
(claude-opus-4-1)}

log(f"Using Claude Opus 4.1 non-reasoning model: \{model\}")

\emph{return} {[}model{]}

def \textbf{discover\_grok\_models}() -\textgreater{} List{[}str{]}:

"""Return Grok 4.1 Fast non-reasoning model."""

\emph{\# Grok 4.1 Fast - optimized for speed, non-reasoning model}

\emph{\# Order of preference: Grok 4.1 Fast, then fallbacks}

preferred\_models = {[}

"grok-4-1-fast-non-reasoning", \emph{\# Grok 4.1 Fast non-reasoning
(primary)}

"grok-4.1-fast", \emph{\# Alternative naming}

"grok-4-fast", \emph{\# Grok 4 Fast}

"grok-4.1", \emph{\# Grok 4.1 (fallback)}

"grok-2", \emph{\# Fallback to Grok 2}

{]}

\emph{\# Exclude reasoning models}

reasoning\_indicators = {[}"reasoning", "think", "cot"{]}

exclude\_indicators = {[}"embed", "code"{]} + reasoning\_indicators

\emph{if} not XAI\_API\_KEY:

\emph{\# Return Grok 4.1 Fast as fallback}

model = preferred\_models{[}0{]} \emph{\# grok-4-1-fast-non-reasoning}

log(f"Grok API key not available, using Grok 4.1 Fast non-reasoning
model: \{model\}")

\emph{return} {[}model{]}

available\_models = {[}{]}

\emph{try}:

\emph{\# x.ai API endpoint for models}

headers = \{

"Authorization": f"Bearer \{XAI\_API\_KEY\}",

"Content-Type": "application/json"

\}

response = requests.get("https://api.x.ai/v1/models",
\emph{headers}=headers, \emph{timeout}=10)

\emph{if} response.status\_code == 200:

data = response.json()

available\_model\_ids = \{model.get("id", "").lower() \emph{for} model
\emph{in} data.get("data", {[}{]})\}

\emph{\# Return the first preferred non-reasoning model
that\textquotesingle s available}

\emph{for} model \emph{in} preferred\_models:

model\_lower = model.lower()

\emph{if} model\_lower in available\_model\_ids:

\emph{\# Double-check it\textquotesingle s not a reasoning model}

\emph{if} not any(r \emph{in} model\_lower \emph{for} r \emph{in}
reasoning\_indicators):

available\_models = {[}model{]}

log(f"Using Grok 4.1 Fast non-reasoning model: \{model\}")

\emph{break}

\emph{except} Exception \emph{as} e:

log\_warn(f"Error checking Grok models, using fallback: \{e\}")

\emph{if} not available\_models:

available\_models = {[}preferred\_models{[}0{]}{]} \emph{\# Fallback to
Grok 4.1 Fast}

log(f"Using fallback Grok 4.1 Fast non-reasoning model:
\{available\_models{[}0{]}\}")

\emph{return} available\_models

def \textbf{discover\_together\_models}() -\textgreater{} List{[}str{]}:

"""Return Llama 4 Maverick from Together AI."""

\emph{if} not TOGETHER\_API\_KEY:

\emph{\# Return the model as fallback}

model = "meta-llama/Llama-4-Maverick-17B-128E-Instruct"

log(f"Together AI API key not found, using fallback model: \{model\}")

\emph{return} {[}model{]}

\emph{\# Together AI model names for Llama 4 Maverick}

\emph{\# Reference: https://www.together.ai/models/llama-4-maverick}

preferred\_models = {[}

"meta-llama/Llama-4-Maverick-17B-128E-Instruct", \emph{\# Llama 4
Maverick (primary)}

"meta-llama/Llama-4-Maverick-17B-128E-Instruct-Turbo", \emph{\# Turbo
version if available}

{]}

\emph{\# Together AI doesn\textquotesingle t require listing models -
just use the model name}

\emph{\# The API will return an error if the model
doesn\textquotesingle t exist}

model = preferred\_models{[}0{]}

log(f"Using Llama 4 Maverick from Together AI: \{model\}")

\emph{return} {[}model{]}

def \textbf{get\_all\_models}() -\textgreater{} List{[}Tuple{[}str,
str{]}{]}:

"""Get all models from all providers as (provider, model) tuples."""

models = {[}{]}

\emph{\# Together AI models (Llama 4 Maverick) - test FIRST}

\emph{for} model \emph{in} discover\_together\_models():

models.append(("together", model))

\emph{\# OpenAI models}

\emph{for} model \emph{in} discover\_openai\_models():

models.append(("openai", model))

\emph{\# Claude models}

\emph{for} model \emph{in} discover\_claude\_models():

models.append(("claude", model))

\emph{\# Grok models}

\emph{for} model \emph{in} discover\_grok\_models():

models.append(("grok", model))

\emph{\# Gemini models - test last to avoid rate limit issues affecting
other models}

\emph{for} model \emph{in} discover\_gemini\_models():

models.append(("gemini", model))

log(f"Total models to test: \{len(models)\}")

\emph{return} models

\emph{\# ────────── API Query Functions ──────────}

def \textbf{ask\_openai}(\emph{model}: str, \emph{prompt}: str)
-\textgreater{} str:

"""Query OpenAI API."""

\emph{if} not OPENAI\_CLIENT:

\emph{return} "unknown"

\emph{for} attempt \emph{in} range(MAX\_RETRIES):

\emph{try}:

\emph{\# Build request parameters}

request\_params = \{

"model": \emph{model},

"messages": {[}\{"role": "user", "content": \emph{prompt}\}{]},

"temperature": 0.0,

"timeout": TIMEOUT\_SEC,

\}

\emph{\# For GPT-5.1, use max\_completion\_tokens instead of max\_tokens
and set reasoning\_effort}

\emph{if} "gpt-5.1" in \emph{model}.lower() or "gpt-5" in
\emph{model}.lower():

\emph{\# GPT-5.1 may need more tokens even with
reasoning\_effort="none"}

\emph{\# Increase to allow the model to generate a response}

request\_params{[}"max\_completion\_tokens"{]} = 50

request\_params{[}"reasoning\_effort"{]} = "none"

\emph{else}:

\emph{\# For other models, use max\_tokens}

request\_params{[}"max\_tokens"{]} = 10

response = OPENAI\_CLIENT.chat.completions.create(**request\_params)

\emph{\# Handle None or empty content - this is the main issue causing
"unknown" responses}

content = response.choices{[}0{]}.message.content

\emph{if} content is None:

log\_err(f"OpenAI returned None content for \{\emph{model}\} on attempt
\{attempt + 1\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

stripped = content.strip()

\emph{if} not stripped:

log\_err(f"OpenAI returned empty content for \{\emph{model}\} on attempt
\{attempt + 1\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{return} stripped

\emph{except} openai.RateLimitError:

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"OpenAI rate limit, waiting \{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

log\_err(f"OpenAI rate limit exceeded for \{\emph{model}\}")

\emph{return} "unknown"

\emph{except} openai.APITimeoutError:

log\_err(f"OpenAI timeout for \{\emph{model}\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{except} openai.NotFoundError:

log\_err(f"OpenAI model not found: \{\emph{model}\}")

\emph{return} "unknown"

\emph{except} openai.BadRequestError \emph{as} e:

\emph{\# Handle invalid parameter errors (e.g., model
doesn\textquotesingle t exist or parameter not supported)}

error\_msg = str(e).lower()

log\_err(f"OpenAI bad request for \{\emph{model}\}: \{e\}")

\emph{\# If it\textquotesingle s a model not found or invalid parameter,
don\textquotesingle t retry}

\emph{if} "model" in error\_msg and ("not found" in error\_msg or
"invalid" in error\_msg or "does not exist" in error\_msg):

\emph{return} "unknown"

\emph{\# If it\textquotesingle s a parameter error, try without the
problematic parameter}

\emph{if} "max\_completion\_tokens" in error\_msg or "reasoning\_effort"
in error\_msg:

log\_warn(f"Parameter error for \{\emph{model}\}, may need to use
different parameters")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{except} Exception \emph{as} e:

error\_str = str(e).lower()

error\_type = type(e).\_\_name\_\_

\emph{\# Log the full error for debugging}

log\_err(f"OpenAI error for \{\emph{model}\} (attempt \{attempt + 1\}):
\{error\_type\}: \{e\}")

\emph{\# Handle network errors}

\emph{if} "connection" in error\_str or "network" in error\_str:

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"OpenAI network error, retrying in \{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

\emph{\# For other errors, retry}

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{return} "unknown"

def \textbf{ask\_gemini}(\emph{model}: str, \emph{prompt}: str)
-\textgreater{} str:

"""Query Google Gemini API."""

\emph{if} not GEMINI\_CLIENT:

\emph{return} "unknown"

\emph{\# Add small delay to throttle requests and prevent overwhelming
API}

time.sleep(0.5)

\emph{for} attempt \emph{in} range(MAX\_RETRIES):

\emph{try}:

\emph{\# Use the model name directly or construct full path}

model\_name = f"models/\{\emph{model}\}" \emph{if} not
\emph{model}.startswith("models/") \emph{else} \emph{model}

gen\_model = GEMINI\_CLIENT.GenerativeModel(model\_name)

\emph{\# Build generation config}

generation\_config = \{

"temperature": 0.0,

"max\_output\_tokens": 50, \emph{\# Increased to ensure response}

\}

\emph{\# For Gemini 3 models, use REST API directly to pass
thinking\_level}

\emph{\# The python SDK doesn\textquotesingle t support thinking\_level
in GenerationConfig yet}

\emph{if} "gemini-3" in \emph{model}.lower() and "flash" not in
\emph{model}.lower():

\emph{\# Use REST API directly for Gemini 3 to support thinking\_level}

\emph{import} json

api\_key = os.getenv("GOOGLE\_API\_KEY")

\emph{if} not api\_key:

\emph{return} "unknown"

url =
f"https://generativelanguage.googleapis.com/v1beta/\{model\_name\}:generateContent"

headers = \{

"Content-Type": "application/json",

\}

\emph{\# FIX 1: Increase maxOutputTokens to 200 when using
thinkingConfig}

\emph{\# thinkingConfig uses \textasciitilde100 tokens for "thoughts"
even at "low" level}

\emph{\# Need 200+ tokens to ensure room for both thinking and output}

max\_tokens = 200 \emph{if} attempt == 0 \emph{else} 300 \emph{\#
Increase on retry}

payload = \{

"contents": {[}\{

"parts": {[}\{"text": \emph{prompt}\}{]}

\}{]},

"generationConfig": \{

"temperature": 0.0,

"maxOutputTokens": max\_tokens,

"thinkingConfig": \{

"thinking\_level": "low" \emph{\# Use thinkingConfig.thinking\_level for
Gemini 3}

\}

\}

\}

\emph{try}:

response = requests.post(

f"\{url\}?key=\{api\_key\}",

\emph{headers}=headers,

\emph{json}=payload,

\emph{timeout}=TIMEOUT\_SEC

)

\emph{\# FIX 4: Add comprehensive logging}

\emph{if} response.status\_code == 200:

result = response.json()

\emph{\# Log token usage for debugging}

usage = result.get("usageMetadata", \{\})

\emph{if} usage:

thoughts\_tokens = usage.get("thoughtsTokenCount", 0)

total\_tokens = usage.get("totalTokenCount", 0)

\emph{if} thoughts\_tokens \textgreater{} 0:

log(f"Gemini \{\emph{model}\} token usage: \{thoughts\_tokens\}
thoughts, \{total\_tokens\} total")

\emph{if} "candidates" in result and len(result{[}"candidates"{]})
\textgreater{} 0:

candidate = result{[}"candidates"{]}{[}0{]}

finish\_reason = candidate.get("finishReason")

\emph{\# FIX 2: Handle MAX\_TOKENS finishReason explicitly}

\emph{if} finish\_reason == "MAX\_TOKENS":

log\_warn(f"Gemini \{\emph{model}\} MAX\_TOKENS - thinking used all
tokens, retrying with more tokens")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

\emph{\# Retry with more tokens}

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{else}:

\emph{\# Last attempt failed, try without thinkingConfig}

log\_warn(f"Gemini \{\emph{model}\} retrying without thinkingConfig")

payload\_no\_thinking = \{

"contents": {[}\{"parts": {[}\{"text": \emph{prompt}\}{]}\}{]},

"generationConfig": \{

"temperature": 0.0,

"maxOutputTokens": 50,

\}

\}

response = requests.post(

f"\{url\}?key=\{api\_key\}",

\emph{headers}=headers,

\emph{json}=payload\_no\_thinking,

\emph{timeout}=TIMEOUT\_SEC

)

\emph{if} response.status\_code == 200:

result = response.json()

\emph{if} "candidates" in result and len(result{[}"candidates"{]})
\textgreater{} 0:

candidate = result{[}"candidates"{]}{[}0{]}

finish\_reason = candidate.get("finishReason")

\emph{\# Check finish reason}

\emph{if} finish\_reason == "SAFETY":

log\_warn(f"Gemini safety filter triggered for \{\emph{model}\}")

\emph{return} "unknown"

\emph{\# FIX 2: Check for empty content dict}

\emph{if} "content" in candidate:

content = candidate{[}"content"{]}

\emph{\# Handle empty content dict}

\emph{if} not content or (isinstance(content, dict) and not
content.get("parts")):

log\_warn(f"Gemini \{\emph{model}\} returned empty content,
finishReason=\{finish\_reason\}")

\emph{if} finish\_reason == "MAX\_TOKENS" and attempt \textless{}
MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{\# Extract text from parts}

\emph{if} "parts" in content and isinstance(content{[}"parts"{]}, list):

\emph{for} part \emph{in} content{[}"parts"{]}:

\emph{if} isinstance(part, dict) and "text" in part:

text = part{[}"text"{]}.strip()

\emph{if} text:

\emph{return} text

\emph{else}:

log\_warn(f"Gemini \{\emph{model}\} no content in candidate,
finishReason=\{finish\_reason\}")

\emph{\# No valid response found}

log\_warn(f"Gemini \{\emph{model}\} no valid response from API")

\emph{return} "unknown"

\emph{elif} response.status\_code == 429:

\emph{\# Rate limit - parse Retry-After header if available, but use
shorter waits}

retry\_after =
response.headers.get(\textquotesingle Retry-After\textquotesingle)

\emph{if} retry\_after:

\emph{try}:

\emph{\# Use the retry-after value, respect it but add buffer}

wait\_seconds = int(retry\_after) + 5 \emph{\# Respect Retry-After, add
buffer}

log\_warn(f"Gemini rate limit (429), Retry-After: \{retry\_after\}s,
waiting \{wait\_seconds\}s")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(wait\_seconds)

\emph{continue}

\emph{except} (ValueError, TypeError):

\emph{pass}

\emph{\# Fall through to exception handler with rate limit info}

\emph{raise} Exception(f"Rate limit 429: \{response.text{[}:200{]}\}")

\emph{elif} response.status\_code \textgreater= 400:

\emph{\# Error response - log and raise}

error\_text = response.text{[}:500{]} \emph{\# Limit error text length}

log\_err(f"Gemini REST API error \{response.status\_code\} for
\{\emph{model}\}: \{error\_text\}")

\emph{raise} Exception(f"API error \{response.status\_code\}:
\{error\_text\}")

\emph{else}:

log\_err(f"Gemini REST API unexpected status \{response.status\_code\}
for \{\emph{model}\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{except} requests.Timeout:

log\_err(f"Gemini REST API timeout for \{\emph{model}\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{except} requests.RequestException \emph{as} e:

log\_err(f"Gemini REST API request error for \{\emph{model}\}: \{e\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{else}:

\emph{\# Use SDK for non-Gemini-3 models}

response = gen\_model.generate\_content(

\emph{prompt},

\emph{generation\_config}=generation\_config

)

\emph{\# Handle SDK response object}

\emph{if} hasattr(response, \textquotesingle candidates\textquotesingle)
and response.candidates:

candidate = response.candidates{[}0{]}

\emph{\# Check finish reason}

finish\_reason = getattr(candidate,
\textquotesingle finish\_reason\textquotesingle, None)

\emph{if} finish\_reason == 2: \emph{\# SAFETY - content blocked}

log\_warn(f"Gemini safety filter triggered for \{\emph{model}\}")

\emph{return} "unknown"

\emph{\# Try to get text from content.parts}

\emph{if} hasattr(candidate, \textquotesingle content\textquotesingle)
and hasattr(candidate.content, \textquotesingle parts\textquotesingle):

\emph{for} part \emph{in} candidate.content.parts:

\emph{if} hasattr(part, \textquotesingle text\textquotesingle) and
part.text:

\emph{return} part.text.strip()

\emph{\# Fallback to response.text if available}

\emph{if} hasattr(response, \textquotesingle text\textquotesingle) and
response.text:

\emph{return} response.text.strip()

\emph{return} "unknown"

\emph{except} Exception \emph{as} e:

error\_str = str(e).lower()

error\_type = type(e).\_\_name\_\_

\emph{\# Handle "Unknown field" errors (like thinking\_level)}

\emph{if} "unknown field" in error\_str or "Unknown field" in str(e):

log\_err(f"Gemini parameter error for \{\emph{model}\}: \{e\}")

\emph{\# Don\textquotesingle t retry with same parameters, return
unknown}

\emph{if} attempt == 0 and "thinking" in error\_str.lower():

log\_warn(f"Removing unsupported parameter and retrying
\{\emph{model}\}")

\emph{\# Could retry without the problematic parameter, but for now just
return unknown}

\emph{return} "unknown"

\emph{\# Handle rate limits and quotas}

\emph{if} "rate" in error\_str or "quota" in error\_str or "429" in
str(e) or "ResourceExhausted" in error\_type:

\emph{\# Use more retries for rate limit errors}

max\_retries\_for\_rate\_limit = MAX\_RETRIES\_RATE\_LIMIT \emph{if}
("429" in str(e) or "rate limit" in error\_str) \emph{else} MAX\_RETRIES

\emph{if} attempt \textless{} max\_retries\_for\_rate\_limit - 1:

\emph{\# Extract retry delay from error if available}

wait\_time = RETRY\_DELAY * (2 ** attempt)

\emph{\# Try to extract wait time from error message}

\emph{if} "retry in" in error\_str or "retry\_delay" in error\_str:

\emph{import} re

retry\_match = re.search(r\textquotesingle retry in
({[}\textbackslash d.{]}+)s\textquotesingle, error\_str)

\emph{if} retry\_match:

wait\_time = float(retry\_match.group(1)) + 5 \emph{\# Add buffer}

\emph{\# For rate limits, use longer exponential backoff to let quota
reset}

\emph{if} "429" in str(e) or "rate limit" in error\_str:

wait\_time = 30 * (2 ** attempt) \emph{\# Start at 30s, double each
retry: 30s, 60s, 120s}

log\_warn(f"Gemini rate limit, waiting \{wait\_time\}s (attempt
\{attempt + 1\}/\{max\_retries\_for\_rate\_limit\})")

time.sleep(wait\_time)

\emph{continue}

log\_err(f"Gemini rate limit exceeded for \{\emph{model}\} after
\{max\_retries\_for\_rate\_limit\} attempts")

\emph{return} "unknown"

\emph{\# Handle timeouts}

\emph{elif} "timeout" in error\_str or "timed out" in error\_str:

log\_err(f"Gemini timeout for \{\emph{model}\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{\# Handle invalid model errors}

\emph{elif} "not found" in error\_str or "invalid" in error\_str or
"404" in str(e):

log\_err(f"Gemini model not found or invalid: \{\emph{model}\}")

\emph{return} "unknown"

\emph{\# Handle network errors}

\emph{elif} "connection" in error\_str or "network" in error\_str:

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"Gemini network error, retrying in \{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

log\_err(f"Gemini network error for \{\emph{model}\}")

\emph{return} "unknown"

\emph{\# General error handling}

\emph{else}:

log\_err(f"Gemini error for \{\emph{model}\}: \{e\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{return} "unknown"

def \textbf{ask\_claude}(\emph{model}: str, \emph{prompt}: str)
-\textgreater{} str:

"""Query Anthropic Claude API."""

\emph{if} not ANTHROPIC\_CLIENT:

