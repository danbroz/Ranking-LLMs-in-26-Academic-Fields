\emph{if} "not found" in error\_str or "invalid" in error\_str or "404"
in str(e):

log\_err(f"Claude model not found or invalid: \{\emph{model}\}")

\emph{return} "unknown"

\emph{\# Handle network errors}

\emph{if} "connection" in error\_str or "network" in error\_str:

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"Claude network error, retrying in \{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

\emph{\# General error handling}

log\_err(f"Claude error for \{\emph{model}\}: \{e\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{return} "unknown"

def \textbf{ask\_grok}(\emph{model}: str, \emph{prompt}: str)
-\textgreater{} str:

"""Query x.ai Grok API."""

\emph{if} not XAI\_API\_KEY:

\emph{return} "unknown"

\emph{for} attempt \emph{in} range(MAX\_RETRIES):

\emph{try}:

headers = \{

"Authorization": f"Bearer \{XAI\_API\_KEY\}",

"Content-Type": "application/json"

\}

data = \{

"model": \emph{model},

"messages": {[}\{"role": "user", "content": \emph{prompt}\}{]},

"temperature": 0.0,

"max\_tokens": 10,

\}

response = requests.post(

"https://api.x.ai/v1/chat/completions",

\emph{headers}=headers,

\emph{json}=data,

\emph{timeout}=TIMEOUT\_SEC

)

\emph{if} response.status\_code == 200:

result = response.json()

\emph{return}
result{[}"choices"{]}{[}0{]}{[}"message"{]}{[}"content"{]}.strip()

\emph{elif} response.status\_code == 429:

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"Grok rate limit, waiting \{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

log\_err(f"Grok rate limit exceeded for \{\emph{model}\}")

\emph{return} "unknown"

\emph{elif} response.status\_code == 404:

log\_err(f"Grok model not found: \{\emph{model}\}")

\emph{return} "unknown"

\emph{elif} response.status\_code \textgreater= 500:

\emph{\# Server error, retry}

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"Grok server error \{response.status\_code\}, retrying in
\{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

log\_err(f"Grok server error for \{\emph{model}\}:
\{response.status\_code\}")

\emph{return} "unknown"

\emph{else}:

log\_err(f"Grok error for \{\emph{model}\}: \{response.status\_code\} -
\{response.text\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{except} requests.Timeout:

log\_err(f"Grok timeout for \{\emph{model}\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{except} requests.ConnectionError:

log\_err(f"Grok connection error for \{\emph{model}\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"Retrying in \{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

\emph{return} "unknown"

\emph{except} Exception \emph{as} e:

log\_err(f"Grok error for \{\emph{model}\}: \{e\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{return} "unknown"

def \textbf{ask\_together}(\emph{model}: str, \emph{prompt}: str)
-\textgreater{} str:

"""Query Together AI API for Llama 4 Maverick.

Together AI provides OpenAI-compatible API for Llama 4 Maverick.

Reference: https://www.together.ai/models/llama-4-maverick

API Docs: https://docs.together.ai/docs/inference

"""

\emph{if} not TOGETHER\_API\_KEY:

\emph{return} "unknown"

\emph{for} attempt \emph{in} range(MAX\_RETRIES):

\emph{try}:

headers = \{

"Authorization": f"Bearer \{TOGETHER\_API\_KEY\}",

"Content-Type": "application/json"

\}

\emph{\# Together AI uses OpenAI-compatible chat completions API}

data = \{

"model": \emph{model},

"messages": {[}\{"role": "user", "content": \emph{prompt}\}{]},

"temperature": 0.0,

"max\_tokens": 50, \emph{\# Short response for quiz answers}

\}

response = requests.post(

TOGETHER\_API\_URL,

\emph{headers}=headers,

\emph{json}=data,

\emph{timeout}=TIMEOUT\_SEC

)

\emph{if} response.status\_code == 200:

result = response.json()

\emph{if} "choices" in result and len(result{[}"choices"{]})
\textgreater{} 0:

content = result{[}"choices"{]}{[}0{]}.get("message",
\{\}).get("content", "").strip()

\emph{if} content:

\emph{return} content

log\_warn(f"Together AI returned empty response for \{\emph{model}\}")

\emph{return} "unknown"

\emph{elif} response.status\_code == 429:

\emph{\# Rate limit}

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"Together AI rate limit, waiting \{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

log\_err(f"Together AI rate limit exceeded for \{\emph{model}\}")

\emph{return} "unknown"

\emph{elif} response.status\_code == 401:

log\_err(f"Together AI authentication error for \{\emph{model}\} - check
API key")

\emph{return} "unknown"

\emph{elif} response.status\_code == 404:

log\_err(f"Together AI model not found: \{\emph{model}\}")

\emph{return} "unknown"

\emph{else}:

error\_text = response.text{[}:500{]} \emph{if} hasattr(response,
\textquotesingle text\textquotesingle) \emph{else}
str(response.status\_code)

log\_err(f"Together AI error \{response.status\_code\} for
\{\emph{model}\}: \{error\_text\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{except} requests.Timeout:

log\_err(f"Together AI timeout for \{\emph{model}\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{except} requests.ConnectionError:

log\_err(f"Together AI connection error for \{\emph{model}\}")

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"Retrying in \{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

\emph{return} "unknown"

\emph{except} Exception \emph{as} e:

error\_str = str(e).lower()

log\_err(f"Together AI error for \{\emph{model}\}: \{e\}")

\emph{if} "rate" in error\_str or "429" in str(e):

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"Together AI rate limit, waiting \{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

time.sleep(RETRY\_DELAY)

\emph{continue}

\emph{return} "unknown"

\emph{return} "unknown"

def \textbf{ask\_api}(\emph{provider}: str, \emph{model}: str,
\emph{prompt}: str) -\textgreater{} str:

"""Unified wrapper to call appropriate API based on provider."""

\emph{if} \emph{provider} == "together":

\emph{return} ask\_together(\emph{model}, \emph{prompt})

\emph{elif} \emph{provider} == "openai":

\emph{return} ask\_openai(\emph{model}, \emph{prompt})

\emph{elif} \emph{provider} == "gemini":

\emph{return} ask\_gemini(\emph{model}, \emph{prompt})

\emph{elif} \emph{provider} == "claude":

\emph{return} ask\_claude(\emph{model}, \emph{prompt})

\emph{elif} \emph{provider} == "grok":

\emph{return} ask\_grok(\emph{model}, \emph{prompt})

\emph{else}:

log\_err(f"Unknown provider: \{\emph{provider}\}")

\emph{return} "unknown"

\emph{\# ────────── Validation and Scoring (from quiz.py) ──────────}

def \textbf{looks\_like\_filler\_response}(\emph{text}: str)
-\textgreater{} bool:

"""Check if response looks like filler text."""

lowered = \emph{text}.lower()

\emph{return} any(hint \emph{in} lowered \emph{for} hint \emph{in}
FILLER\_HINTS)

def \textbf{normalize\_and\_validate}(\emph{raw}: str) -\textgreater{}
Tuple{[}str, bool, str{]}:

"""Normalize and validate response, same as quiz.py."""

\emph{if} \emph{raw} is None:

\emph{return} "unknown", False, "Empty response"

stripped = \emph{raw}.strip()

\emph{if} not stripped:

\emph{return} "unknown", False, "Empty response"

normalized = " ".join(stripped.lower().split())

normalized = ALIAS.get(normalized, normalized)

\emph{if} re.fullmatch(r"{[}1-5{]}(?:{[}).{]})?", normalized):

mapped = NUMERIC\_CHOICES{[}normalized{[}0{]}{]}

\emph{return} mapped, True, "Numeric choice"

\emph{if} normalized in VALID\_ANSWERS and stripped.lower() ==
normalized:

\emph{return} normalized, True, "Exact match"

stripped\_no\_punct = stripped.rstrip(".!,?:;")

collapsed\_no\_punct = " ".join(stripped\_no\_punct.lower().split())

collapsed\_no\_punct = ALIAS.get(collapsed\_no\_punct,
collapsed\_no\_punct)

\emph{if} collapsed\_no\_punct in VALID\_ANSWERS:

\emph{return} collapsed\_no\_punct, False, "Answer must be exactly one
word/phrase with no punctuation."

\emph{for} phrase, mapped \emph{in} FILLER\_PHRASES.items():

\emph{if} phrase in normalized:

\emph{return} mapped, True, f"Alias phrase
\textquotesingle\{phrase\}\textquotesingle"

word\_tokens = {[}token \emph{for} token \emph{in}
re.split(r"{[}\^{}a-z{]}+", normalized) \emph{if} token{]}

\emph{if} word\_tokens:

\emph{for} target, synonyms \emph{in} FILLER\_SYNONYMS.items():

\emph{for} synonym \emph{in} synonyms:

\emph{if} synonym in word\_tokens:

\emph{return} target, True, f"Alias keyword
\textquotesingle\{synonym\}\textquotesingle"

\emph{for} token \emph{in} VALID\_ANSWERS:

\emph{if} token in normalized:

\emph{return} token, True, "Salvaged token from verbose response"

\emph{return} "unknown", False, "Answer must be exactly one of: true,
false, possibly true, possibly false, unknown."

def \textbf{build\_reprompt\_prompt}(\emph{base\_prompt}: str,
\emph{reason}: str, \emph{previous}: str) -\textgreater{} str:

"""Build reprompt with error feedback."""

reason\_text = \emph{reason} or "the answer was not in the valid list"

normalized\_previous = " ".join(\emph{previous}.strip().split()) or "∅"

normalized\_previous =
normalized\_previous.replace(\textquotesingle"\textquotesingle,
"\textquotesingle")

\emph{return}
f"\{\emph{base\_prompt}\}\{REPROMPT\_TEMPLATE.format(\emph{answer}=normalized\_previous,
\emph{reason}=reason\_text)\}"

def \textbf{get\_validated\_answer}(\emph{provider}: str, \emph{model}:
str, \emph{base\_prompt}: str) -\textgreater{} Tuple{[}str, str, int,
bool, str{]}:

"""Get validated answer with retries, same logic as quiz.py."""

attempts = 0

prompt = \emph{base\_prompt}

last\_raw = ""

\emph{while} attempts \textless{} MAX\_REPROMPTS:

raw\_response = ask\_api(\emph{provider}, \emph{model}, prompt)

normalized, valid, reason = normalize\_and\_validate(raw\_response)

\emph{if} valid:

reason\_tag = "other"

\emph{if} reason:

\emph{if} reason.startswith("Alias"):

log(f"Alias normalization -\textgreater{} \{normalized\} \textbar{}
\{reason\} \textbar{}
raw=\textquotesingle\{raw\_response\}\textquotesingle")

reason\_tag = "alias"

\emph{elif} reason == "Numeric choice":

log(f"Numeric choice -\textgreater{} \{normalized\} \textbar{}
raw=\textquotesingle\{raw\_response\}\textquotesingle")

reason\_tag = "numeric"

\emph{elif} reason == "Salvaged token from verbose response":

log(f"Salvaged verbose -\textgreater{} \{normalized\} \textbar{}
raw=\textquotesingle\{raw\_response\}\textquotesingle")

reason\_tag = "salvaged\_verbose"

\emph{elif} reason == "Exact match":

log(f"Exact match -\textgreater{} \{normalized\}")

reason\_tag = "exact"

\emph{else}:

log(f"\{reason\} -\textgreater{} \{normalized\} \textbar{}
raw=\textquotesingle\{raw\_response\}\textquotesingle")

\emph{else}:

reason\_tag = "exact"

\emph{return} normalized, raw\_response, attempts + 1, True, reason\_tag

filler\_hit = looks\_like\_filler\_response(raw\_response) \emph{if}
raw\_response \emph{else} False

reprompt\_reason = reason

\emph{if} filler\_hit:

preview = (raw\_response or "").strip().replace("\textbackslash n", "
"){[}:80{]}

log(f"Filler invalid (provider=\{\emph{provider}\},
model=\{\emph{model}\}, attempt=\{attempts + 1\}) -\textgreater{}
\textquotesingle\{preview\}\textquotesingle")

\emph{if} attempts == 0:

reprompt\_reason = "your reply began with filler text instead of one of
the allowed words"

\emph{else}:

normalized = normalized \emph{if} normalized in VALID\_ANSWERS
\emph{else} "unknown"

log(f"Filler repeated (provider=\{\emph{provider}\},
model=\{\emph{model}\}, attempt=\{attempts + 1\}) -\textgreater{}
\textquotesingle\{preview\}\textquotesingle{} \textbar{} aborting")

\emph{return} normalized, raw\_response, attempts + 1, False,
"filler\_skipped"

attempts += 1

last\_raw = raw\_response

\emph{if} attempts \textgreater= MAX\_REPROMPTS:

final\_tag = "filler\_invalid" \emph{if} filler\_hit \emph{else}
"invalid"

\emph{return} normalized, last\_raw, attempts, False, final\_tag

prompt = build\_reprompt\_prompt(\emph{base\_prompt}, reprompt\_reason,
last\_raw)

\emph{return} "unknown", last\_raw, attempts, False, "invalid"

def \textbf{build\_prompt}(\emph{field}: str, \emph{q}: str,
\emph{year}: int \textbar{} None) -\textgreater{} str:

"""Build prompt with instructions, same as quiz.py."""

yr = f"The paper was published in \{\emph{year}\}. " \emph{if}
\emph{year} \emph{else} ""

instructions = (

"Respond with exactly one lowercase word: true, false, possibly true,
possibly false, unknown.\textbackslash n"

"Do not add sentences, introductions, or punctuation---phrases like
\textbackslash"here is\textbackslash" or \textbackslash"the answer
is\textbackslash" are invalid.\textbackslash n"

"Copy the word exactly as spelled above. If you cannot decide, reply
unknown. Never leave the reply blank.\textbackslash n"

)

context = f"You are being quizzed in \{\emph{field}\}. \{yr\}"

\emph{return}
f"\{instructions\}\{context\}Question:\textbackslash n\{\emph{q}\}"

def \textbf{score}(\emph{gt}: str, \emph{pred}: str) -\textgreater{}
float:

"""Score prediction against ground truth, same as quiz.py."""

\emph{if} \emph{pred} == "unknown":

\emph{return} 0.0

\emph{if} (\emph{gt} in TRUE\_SET and \emph{pred} in TRUE\_SET) or
(\emph{gt} in FALSE\_SET and \emph{pred} in FALSE\_SET):

\emph{return} CORRECT\_SCORE

\emph{return} INCORRECT\_SCORE

def \textbf{process\_batch}(\emph{batch}: List{[}Tuple{[}int,
Dict{]}{]}, \emph{provider}: str, \emph{model}: str, \emph{field\_name}:
str) -\textgreater{} Tuple{[}float, int{]}:

"""Process a batch of questions, same logic as quiz.py."""

total = 0.0

salvaged\_verbose\_count = 0

full\_model\_name = f"\{\emph{provider}\}:\{\emph{model}\}"

\emph{for} idx, doc \emph{in} \emph{batch}:

q, gt = doc{[}"Question"{]}, doc{[}"Answer"{]}.lower()

year = doc.get("publication\_year")

prompt = build\_prompt(\emph{field\_name}, q, year)

normalized, raw\_answer, attempts\_used, valid\_answer, reason\_tag =
get\_validated\_answer(\emph{provider}, \emph{model}, prompt)

\emph{if} reason\_tag == "salvaged\_verbose":

salvaged\_verbose\_count += 1

\emph{if} not valid\_answer:

\emph{if} normalized not in VALID\_ANSWERS:

normalized = "unknown"

filler\_notice = reason\_tag.startswith("filler\_")

\emph{if} filler\_notice:

\emph{if} reason\_tag == "filler\_skipped":

message = (

f"\{\emph{field\_name}\} \textbar{} \{idx\}/\{QUESTIONS\_PER\_FIELD\}
\textbar{} \{year or \textquotesingle---\textquotesingle\} \textbar{}
\{full\_model\_name\} \textbar{} "

f"filler response detected; no retry issued;
raw=\textquotesingle\{raw\_answer\}\textquotesingle{} -\textgreater{}
using \textquotesingle\{normalized\}\textquotesingle"

)

\emph{else}:

message = (

f"\{\emph{field\_name}\} \textbar{} \{idx\}/\{QUESTIONS\_PER\_FIELD\}
\textbar{} \{year or \textquotesingle---\textquotesingle\} \textbar{}
\{full\_model\_name\} \textbar{} "

f"filler response ignored after \{attempts\_used\} attempts;
raw=\textquotesingle\{raw\_answer\}\textquotesingle{} -\textgreater{}
using \textquotesingle\{normalized\}\textquotesingle"

)

log\_err(message)

\emph{else}:

message = (

f"\{\emph{field\_name}\} \textbar{} \{idx\}/\{QUESTIONS\_PER\_FIELD\}
\textbar{} \{year or \textquotesingle---\textquotesingle\} \textbar{}
\{full\_model\_name\} \textbar{} "

f"invalid response after \{attempts\_used\} attempts;
raw=\textquotesingle\{raw\_answer\}\textquotesingle{} -\textgreater{}
using \textquotesingle\{normalized\}\textquotesingle"

)

\emph{if} normalized == "unknown" and attempts\_used \textgreater{} 1:

log\_err(message)

\emph{elif} normalized == "unknown":

log(message)

\emph{else}:

log(message)

sc = score(gt, normalized)

res = "✅" \emph{if} sc \textgreater{} 0 \emph{else} "❌" \emph{if} sc
\textless{} 0 \emph{else} "☐"

attempt\_info = f"attempts:\{attempts\_used\}"

log(

f"\{\emph{field\_name}\} \textbar{} \{idx\}/\{QUESTIONS\_PER\_FIELD\}
\textbar{} \{year or \textquotesingle---\textquotesingle\} \textbar{}
\{full\_model\_name\} \textbar{} "

f"GT:\{gt\} \textbar{} LLM:\{raw\_answer\} -\textgreater{}
\{normalized\} \textbar{} \{res\} \textbar{} \{attempt\_info\}"

)

total += sc

\emph{return} total, salvaged\_verbose\_count

def \textbf{header}() -\textgreater{} List{[}str{]}:

"""CSV header, same as quiz.py."""

\emph{return} {[}"model", "overall", *FIELD\_MAP.values(),
"timestamp"{]}

def \textbf{done}() -\textgreater{} set{[}str{]}:

"""Get set of completed models from CSV."""

\emph{if} not CSV\_PATH.exists():

\emph{return} set()

\emph{with} CSV\_PATH.open(\emph{newline}="", \emph{encoding}="utf-8")
\emph{as} f:

r = csv.reader(f)

next(r, None)

\emph{return} \{row{[}0{]} \emph{for} row \emph{in} r\}

\emph{\# ────────── main ──────────}

def \textbf{main}():

"""Main evaluation loop, following quiz.py structure."""

global GLOBAL\_SALVAGE\_TOTAL, GLOBAL\_SALVAGE\_BY\_MODEL,
GLOBAL\_SALVAGE\_BY\_FIELD

GLOBAL\_SALVAGE\_TOTAL = 0

GLOBAL\_SALVAGE\_BY\_MODEL = \{\}

GLOBAL\_SALVAGE\_BY\_FIELD = defaultdict(int)

\emph{\# Initialize API clients}

initialize\_api\_clients()

\emph{\# Get all models to test}

all\_models = get\_all\_models()

\emph{if} not all\_models:

log\_err("No models found to test. Check API keys and installations.")

\emph{return}

\emph{\# Connect to MongoDB}

completed = done()

hdr = CSV\_PATH.exists()

\emph{try}:

mongo = MongoClient(MONGO\_URI, \emph{serverSelectionTimeoutMS}=5000)

mongo.admin.command(\textquotesingle ping\textquotesingle)

log("✅ Connected to MongoDB")

\emph{except} Exception \emph{as} e:

log\_err(f"Failed to connect to MongoDB: \{e\}")

\emph{return}

cols = \{db: mongo{[}db{]}{[}"sources"{]} \emph{for} db \emph{in}
DATABASES\}

\emph{\# Process each model}

\emph{for} provider, model \emph{in} all\_models:

full\_model\_name = f"\{provider\}:\{model\}"

\emph{if} full\_model\_name in completed:

log(f"skip \{full\_model\_name\}")

\emph{continue}

log(f"=== MODEL \{full\_model\_name\} ===")

field\_scores: Dict{[}str, float{]} = \{\}

field\_salvage\_counts: Dict{[}str, int{]} = \{\}

model\_salvage\_total = 0

\emph{for} db \emph{in} DATABASES:

fname = FIELD\_MAP{[}db{]}

col = cols{[}db{]}

\emph{try}:

docs = list(col.aggregate({[}

\{"\$match": \{"Question": \{"\$ne": None\}, "Answer": \{"\$in":
list(VALID\_ANSWERS)\}\}\},

\{"\$sample": \{"size": QUESTIONS\_PER\_FIELD\}\}

{]}))

\emph{except} Exception \emph{as} e:

log\_err(f"Error querying \{db\}: \{e\}")

field\_scores{[}fname{]} = 0.0

\emph{continue}

\emph{if} not docs:

log\_warn(f"No questions found for \{fname\}")

field\_scores{[}fname{]} = 0.0

\emph{continue}

indexed\_docs = list(enumerate(docs, 1))

\emph{\# Process in batches with ThreadPoolExecutor}

total = 0.0

field\_salvaged = 0

\emph{\# Reduced concurrency for Gemini to prevent rate limits}

\emph{if} provider == "gemini":

max\_workers = min(3, len(indexed\_docs)) \emph{\# Reduced to 3 to avoid
rate limits}

\emph{else}:

max\_workers = min(16, len(indexed\_docs)) \emph{\# Reasonable
concurrency for other APIs}

\emph{\# Split into batches for parallel processing}

batch\_size = max(1, len(indexed\_docs) // max\_workers)

batches = {[}{]}

\emph{for} i \emph{in} range(0, len(indexed\_docs), batch\_size):

batches.append(indexed\_docs{[}i:i + batch\_size{]})

\emph{with} ThreadPoolExecutor(\emph{max\_workers}=max\_workers)
\emph{as} executor:

futures = {[}

executor.submit(process\_batch, batch, provider, model, fname)

\emph{for} batch \emph{in} batches \emph{if} batch

{]}

\emph{for} future \emph{in} as\_completed(futures):

\emph{try}:

batch\_total, batch\_salvaged = future.result()

total += batch\_total

field\_salvaged += batch\_salvaged

\emph{except} Exception \emph{as} e:

log\_err(f"Error processing batch in \{fname\}: \{e\}")

model\_salvage\_total += field\_salvaged

field\_salvage\_counts{[}fname{]} = field\_salvaged

GLOBAL\_SALVAGE\_BY\_FIELD{[}fname{]} += field\_salvaged

field\_scores{[}fname{]} = round(total, 4)

\emph{\# Calculate overall score and write to CSV}

overall = round(sum(field\_scores.values()) / len(field\_scores), 4)
\emph{if} field\_scores \emph{else} 0.0

row = {[}full\_model\_name, str(overall), *(str(field\_scores.get(f,
0.0)) \emph{for} f \emph{in} FIELD\_MAP.values()),
datetime.now().isoformat(){]}

mode = "a" \emph{if} hdr \emph{else} "w"

\emph{with} CSV\_PATH.open(mode, \emph{newline}="",
\emph{encoding}="utf-8") \emph{as} f:

w = csv.writer(f)

\emph{if} not hdr:

w.writerow(header())

hdr = True

w.writerow(row)

GLOBAL\_SALVAGE\_TOTAL += model\_salvage\_total

GLOBAL\_SALVAGE\_BY\_MODEL{[}full\_model\_name{]} =
model\_salvage\_total

\emph{if} model\_salvage\_total:

per\_field = ", ".join(

f"\{field\}:\{count\}"

\emph{for} field, count \emph{in} field\_salvage\_counts.items()

\emph{if} count

)

log(f"\{full\_model\_name\} salvaged verbose answers:
total=\{model\_salvage\_total\}"

f"\{\textquotesingle{} \textbar{} \textquotesingle{} + per\_field
\emph{if} per\_field \emph{else} \textquotesingle\textquotesingle\}")

log(f"done \{full\_model\_name\}")

mongo.close()

log("🎉 all models done")

\emph{if} GLOBAL\_SALVAGE\_TOTAL:

log(

"Verbose answer salvage summary --- "

f"total:\{GLOBAL\_SALVAGE\_TOTAL\} \textbar{} "

f"models:\{ \{m:c \emph{for} m,c \emph{in}
GLOBAL\_SALVAGE\_BY\_MODEL.items() \emph{if} c\} \} \textbar{} "

f"fields:\{ \{f:c \emph{for} f,c \emph{in}
GLOBAL\_SALVAGE\_BY\_FIELD.items() \emph{if} c\} \}"

)

\emph{if} \_\_name\_\_ == "\_\_main\_\_":

\emph{try}:

main()

\emph{except} KeyboardInterrupt:

log("bye")

\emph{except} Exception \emph{as} e:

log\_err(f"Fatal error: \{e\}")

\emph{raise}

