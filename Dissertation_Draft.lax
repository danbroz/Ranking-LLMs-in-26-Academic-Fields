\emph{except} Exception \emph{as} e:

error\_str = str(e).lower()

\emph{\# Handle rate limits}

is\_rate\_limit = (

"rate" in error\_str or "rate\_limit" in error\_str or "429" in str(e)
or

(hasattr(anthropic, \textquotesingle RateLimitError\textquotesingle) and
isinstance(e, getattr(anthropic,
\textquotesingle RateLimitError\textquotesingle, type(None))))

)

\emph{if} is\_rate\_limit:

\emph{if} attempt \textless{} MAX\_RETRIES - 1:

wait\_time = RETRY\_DELAY * (2 ** attempt)

log\_warn(f"Claude rate limit, waiting \{wait\_time\}s")

time.sleep(wait\_time)

\emph{continue}

log\_err(f"Claude rate limit exceeded for \{\emph{model}\}")

\emph{return} "unknown"

\emph{\# Handle timeouts}

\emph{if} "timeout" in error\_str or "timed out" in error\_str:

